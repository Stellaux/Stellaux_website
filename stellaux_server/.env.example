# ── Database ──────────────────────────────────────────────────────────────
# For native dev pointing at the dockerized Postgres on host:
DATABASE_URL=postgres://stellaux:stellaux_dev_only@localhost:5432/stellaux
# Inside the docker network (when running with --profile full) use:
# DATABASE_URL=postgres://stellaux:stellaux_dev_only@postgres:5432/stellaux

# Connection pool size (sea-orm)
DATABASE_POOL_SIZE=10

# ── Server ────────────────────────────────────────────────────────────────
RUST_LOG=info,stellaux_server=debug
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# Environment marker — gates prod-only behavior like HSTS.
# One of: dev | staging | prod
APP_ENV=dev

# Global per-request deadline, in seconds.
REQUEST_TIMEOUT_SECS=30

# Body limit for normal API routes (2 MiB default).
BODY_LIMIT_BYTES=2097152

# Body limit for webhook routes (10 MiB default — Shippo label PDFs can be large).
WEBHOOK_BODY_LIMIT_BYTES=10485760

# ── Auth (our HS256 tokens) ───────────────────────────────────────────────
# 32+ byte random value; use `openssl rand -base64 48` to generate.
JWT_SECRET=replace-me-with-a-real-secret
JWT_EXPIRY_SECONDS=3600

# Validated against the `iss` / `aud` claims on every verify. Pick values
# unique to this service so a token can never be replayed against a sibling.
JWT_ISSUER=stellaux-api
JWT_AUDIENCE=stellaux-clients

# ── Auth (Supabase RS256, optional) ───────────────────────────────────────
# Set SUPABASE_JWKS_URL to enable verification of Supabase-issued tokens
# via the require_supabase_auth middleware. Leave blank to disable.
# SUPABASE_JWKS_URL=https://ubqozvbtwfnnzzcmlgfb.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_AUDIENCE=authenticated
# Optional — restricts accepted issuer. Leave unset to skip the `iss` check.
# SUPABASE_ISSUER=https://ubqozvbtwfnnzzcmlgfb.supabase.co/auth/v1
JWKS_TTL_SECONDS=3600

# ── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated list of frontends allowed to call this API.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://themaisonaure.com

# ── Stripe ────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SUCCESS_URL=https://themaisonaure.com/order-confirmed
STRIPE_CANCEL_URL=https://themaisonaure.com/checkout

# ── Shippo ────────────────────────────────────────────────────────────────
SHIPPO_API_TOKEN=shippo_test_...
SHIPPO_WEBHOOK_SECRET=

# ── Resend (transactional email) ──────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=orders@themaisonaure.com

# ── Warehouse origin (for Shippo rate quotes) ─────────────────────────────
WAREHOUSE_NAME=
WAREHOUSE_STREET=
WAREHOUSE_CITY=
WAREHOUSE_STATE=
WAREHOUSE_POSTAL_CODE=
WAREHOUSE_COUNTRY=US
WAREHOUSE_PHONE=
